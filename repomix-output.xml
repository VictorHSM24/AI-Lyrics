        s = self.calc.temporal_slice(records, TemporalWindow.LAST_24H,
                                     now=201000.0)
        # r2 (200000) >= 114600 → incluído
        # r1 (1000) < 114600 → excluído
        self.assertEqual(s.record_count, 1)

