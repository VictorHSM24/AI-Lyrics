        results = searcher.search("deus amou o mundo")
        assert len(results) > 0
        for r in results:
            assert 0.0 <= r.score <= 1.0
            assert 0.0 <= r.c_search <= 1.0

    def test_search_results_ordered_by_score(self, searcher: Searcher) -> None:
