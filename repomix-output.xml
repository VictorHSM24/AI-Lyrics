            "log_dir": self.log_dir,
            "cache_dir": self.cache_dir,
            "data_dir": self.data_dir,
            "gpu_name": self.gpu_name,
            "gpu_memory_total_bytes": self.gpu_memory_total_bytes,
            "gpu_memory_used_bytes": self.gpu_memory_used_bytes,
