    def test_bypass_does_not_apply_missing_verse(self, engine: DecisionEngine) -> None:
        """show + verse=None → fluxo normal (bypass exige verse presente)."""
        intent = Intent(
            action="show", book="João", book_id=43, chapter=3, verse=None,
