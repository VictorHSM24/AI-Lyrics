        r = EvaluationReport(generated_at=0, window=TemporalWindow.ALL,
                             summary=s, regressions=(alert,))
        text = r.to_text()
        self.assertIn("Regressões detectadas", text)

    def test_to_dict(self):
        m = EvaluationMetrics(total_searches=10)
