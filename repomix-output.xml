        client = _make_client()
        client.get_bible_versions()
        # Verifica que a URL chamada é GetBibleVersionsV2, não GetBibleVersions.
        call_args = mock_post.call_args
        url = call_args[0][0] if call_args[0] else call_args[1].get("url", "")
