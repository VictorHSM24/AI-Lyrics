        <AppLayout>
          <ConsolePage />
        </AppLayout>
      </ErrorBoundary>
    ),
  },
  {
    path: "/sessoes",
    element: (
      <ErrorBoundary>
        <AppLayout>
          <SessionsPage />
        </AppLayout>
      </ErrorBoundary>
    ),
  },
  {
    path: "/replay",
    element: (
      <ErrorBoundary>
        <AppLayout>
          <ReplayPage />
        </AppLayout>
      </ErrorBoundary>
    ),
  },
  {
    path: "/logs",
    element: (
      <ErrorBoundary>
        <AppLayout>
          <LogsPage />
        </AppLayout>
      </ErrorBoundary>
    ),
  },
  {
    path: "/configuracoes",
    element: (
      <ErrorBoundary>
        <AppLayout>
          <ConfigurationPage />
        </AppLayout>
      </ErrorBoundary>
    ),
  },
  {
    path: "/diagnostico",
    element: (
      <ErrorBoundary>
        <AppLayout>
          <DiagnosticPage />
        </AppLayout>
      </ErrorBoundary>
    ),
  },
  {
    path: "/sobre",
    element: (
      <ErrorBoundary>
        <AppLayout>
          <AboutPage />
        </AppLayout>
      </ErrorBoundary>
    ),
  },
  {
    path: "*",
    element: <NotFoundPage />,
  },
];

export const router = createBrowserRouter(routes);
