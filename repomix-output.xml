# config/books.py — tipos de domínio para livros bíblicos
@dataclass(frozen=True)
class Book: id: int; canonical: str; aliases: list[str]
@dataclass
class BookMatch: book: Book; matched_alias: str; start: int; end: int
class BookTable:
