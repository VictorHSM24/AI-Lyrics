      <Card title="Resumo">
        <div className="flex flex-wrap gap-3 text-xs text-text-muted">
          <span className="inline-flex items-center gap-1">
            <Mic2 className="h-3.5 w-3.5" /> {ai.whisperModel}
          </span>
          <span className="inline-flex items-center gap-1">
            <Cpu className="h-3.5 w-3.5" /> {ai.device} · {ai.computeType}
          </span>
          {ai.llmModel && (
            <span className="inline-flex items-center gap-1">
