          throughput_queries_per_min: 0,
          error_rate: 0,
          drop_rate: 0,
          presentation_success_rate: 0,
          processing_success_rate: 0,
          duration_s: 0,
          correlation_count: 0,
        });
      }
    });
    stream.publish({
      id: "e1",
      type: "MetricsUpdated",
      timestamp: 100,
      correlationId: null,
      payload: {},
    });
    expect(stores.metrics.hasSnapshot).toBe(true);
    expect(stores.metrics.current!.data.segments_received).toBe(1);
  });
});
