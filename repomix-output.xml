def make_engine(clock_start=1000.0):
    clock = [clock_start]
    def fake_clock():
        clock[0] += 1.0
        return clock[0]
    repo = FeedbackRepository()
    return FeedbackEngine(repo, clock=fake_clock), repo


def make_key(scope=FeedbackScope.GLOBAL, query="pedro",
